# Copy this file to .env and fill in your values.

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SECURE_SSL_REDIRECT=true
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# OpenAI / OpenAI-compatible providers (e.g., GitHub Marketplace Models)
# For GitHub Marketplace models, set OPENAI_API_KEY to your GitHub token/key
# and set OPENAI_BASE_URL to the provider's OpenAI-compatible endpoint.
OPENAI_API_KEY=your-openai-compatible-api-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=8
OPENAI_MAX_RETRIES=2

# Preferred in production (managed PostgreSQL, e.g. Render)
# Example:
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname?sslmode=require
# Supabase example:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# Optional (only needed if you also use Supabase client SDKs)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Database (defaults to SQLite in backend/db.sqlite3)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# API Security
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ACCESS_TOKEN_TTL_HOURS=12
ALLOW_DEV_AUTH_ENDPOINTS=false

# Logging
LOG_LEVEL=INFO

# Optional: create an admin user automatically during deploy if set.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
